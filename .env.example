# ── Database ─────────────────────────────────────────────────
DATABASE_URL="mysql://USER:PASSWORD@HOST:3306/aamantran"

# ── App URLs ──────────────────────────────────────────────────
# Local dev (default). On Railway production, use:
#   API_BASE_URL=https://api.aamantran.online
#   LANDING_URL=https://www.aamantran.online
#   ADMIN_URL=https://admin.aamantran.online
#   COUPLE_DASHBOARD_URL=https://app.aamantran.online
API_BASE_URL="http://localhost:4000"
LANDING_URL="http://localhost:3000"
ADMIN_URL="http://localhost:5174"
COUPLE_DASHBOARD_URL="http://localhost:3001"

# ── Storage ───────────────────────────────────────────────────
STORAGE_PATH="./storage"
# Optional: Cloudflare R2 (S3 API). When ALL are set, templates + media go to R2
# and R2_PUBLIC_BASE_URL is used in HTML / DB. Omit for local disk + /s/ + /uploads/.
# R2_ACCOUNT_ID=""
# R2_ACCESS_KEY_ID=""
# R2_SECRET_ACCESS_KEY=""
# R2_BUCKET_NAME="aamantran-prod"
# R2_PUBLIC_BASE_URL="https://media.aamantran.online"

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET="change-this-to-a-random-secret"
JWT_EXPIRES_IN="8h"

# ── Admin Credentials ─────────────────────────────────────────
ADMIN_EMAIL="aamantran@plexzuu.com"
ADMIN_PASSWORD="change-this-password"

# ── PayU payments ─────────────────────────────────────────────
# PAYU_ENV="test" uses https://test.payu.in/_payment; any other value uses prod.
PAYU_ENV="test"
PAYU_MERCHANT_KEY="test_key"
PAYU_MERCHANT_SALT="test_salt"
# Used when admin template-swap emails need a placeholder instead of a real PayU link.
TEMPLATE_SWAP_PLACEHOLDER_PAY_URL="https://aamantran.online/configure-payu"

# ── Email (SMTP via Nodemailer) ───────────────────────────────
SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_USER="smtp-user"
SMTP_PASS="smtp-password"
EMAIL_FROM="aamantran@plexzuu.com"

NODE_ENV="development"
PORT=4000

# Dev/staging only: checkout skips PayU; "Pay Now" completes via /api/checkout/mock-success.
# Never set true in production. mock-success is blocked when NODE_ENV=production.
# DUMMY_PAYMENT_MODE="true"

# Optional rate limits (requests per window) — see src/middleware/rateLimits.js
# RATE_LIMIT_GLOBAL_MAX=600
# RATE_LIMIT_AUTH_MAX=30
# RATE_LIMIT_RECOVERY_MAX=10
# RATE_LIMIT_CHECKOUT_MAX=120
# RATE_LIMIT_PUBLIC_INVITE_MAX=200
# RATE_LIMIT_LOOKUP_MAX=60
# RATE_LIMIT_TRACK_MAX=120

# Set TRUST_PROXY=0 only if the API is never behind a reverse proxy
# TRUST_PROXY=0
